        <!-- 主選單：右對齊 + 英文副標 -->
        <div class="relative z-10 flex-1 flex flex-col justify-center items-end space-y-5 pr-10 pb-4">
            <a href="#about" class="mobile-link group text-right">
                <span class="block text-[1.75rem] font-black text-slate-800 group-hover:text-brand-accent transition-colors duration-300 leading-tight">關於冠恆</span>
