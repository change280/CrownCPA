    </div>

    <!-- 視覺震撼首頁 Hero Section -->
    <section class="relative min-h-[90vh] lg:min-h-screen hero-wash overflow-hidden rounded-b-[3rem] lg:rounded-b-[5rem] flex items-center pt-24 pb-32">
        <!-- 動態發光球體背景 -->
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
            <div class="absolute inset-0 hero-photo-blend opacity-[0.22]"></div>
            <div class="absolute inset-0 bg-grain opacity-35"></div>
            <div class="absolute inset-0 bg-dots opacity-16"></div>
            <div class="absolute inset-0 hero-grid opacity-[0.06]"></div>
            <div class="absolute -top-[8%] -left-[10%] w-[42vw] h-[42vw] rounded-full bg-[#f4ecdc]/10 blur-[120px]"></div>
            <div class="absolute top-[-10%] right-[-5%] w-[40vw] h-[40vw] rounded-full bg-brand-accent/16 blur-[100px] animate-blob"></div>
            <div class="absolute bottom-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-brand-muted/18 blur-[120px] animate-blob animation-delay-2000"></div>
            <div class="absolute top-[40%] left-[20%] w-[30vw] h-[30vw] rounded-full bg-[#d8d0bf]/14 blur-[90px] animate-blob animation-delay-4000"></div>
            <div class="absolute right-[7%] top-[24%] w-[26vw] h-[26vw] rounded-full border border-white/26"></div>
            <div class="absolute left-[5%] bottom-[10%] w-[34vw] h-[34vw] rounded-full border border-white/22"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.08),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(0,0,0,0.10),transparent_34%)]"></div>
        </div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
            <div class="grid lg:grid-cols-[repeat(13,minmax(0,1fr))] gap-10 lg:gap-12 items-center">
                <div class="lg:col-span-8 order-2 lg:order-1">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-brand-muted text-sm font-bold mb-8 backdrop-blur-md">
                        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
                        30年專業傳承・知識整合先驅
                    </div>
