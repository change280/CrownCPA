                    <span class="text-xs font-extrabold text-[#7382a0] hover:text-[#475569] cursor-pointer">JP</span>
                    <span class="text-xs font-extrabold text-[#7382a0] hover:text-[#475569] cursor-pointer">EN</span>
                </div>
                <a href="#contact" class="hidden md:inline-flex px-6 py-2.5 glass-cta text-white rounded-full text-sm font-bold hover:bg-brand-surface hover:shadow-lg hover:shadow-brand-primary/25 transition-all active:scale-95 border border-white/10 md:ml-2">
