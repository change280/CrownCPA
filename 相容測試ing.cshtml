    <!-- 頁面互動 JavaScript -->
    <script>
        // 頁面加載時重置滾動位置到頂部
        window.addEventListener('load', () => {
            window.scrollTo(0, 0);
        });

        // 初始化 Lucide 圖示
        lucide.createIcons();

        // 導覽列懸浮與滾動效果
        const navContainer = document.getElementById('nav-container');
        let lastScroll = 0;
        
        window.addEventListener('scroll', () => {
            const currentScroll = window.scrollY;
            
            // 處理導覽列外觀
            if (currentScroll > 50) {
                navContainer.classList.add('top-2');
                navContainer.classList.remove('top-6');
            } else {
                navContainer.classList.add('top-6');
                navContainer.classList.remove('top-2');
            }
            
            // 向下滾動隱藏導覽列，向上滾動顯示 (增強沉浸感)
            if (currentScroll > lastScroll && currentScroll > 200) {
                // 向下滾動
                navContainer.style.transform = 'translateY(-150%)';
            } else {
                // 向上滾動
                navContainer.style.transform = 'translateY(0)';
            }
            lastScroll = currentScroll;
        });

        // 手機版全螢幕選單切換
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        mobileMenuBtn.addEventListener('click', () => {
            const isHidden = mobileMenu.classList.contains('hidden');
            
            if (isHidden) {
                mobileMenu.classList.remove('hidden');
                // 延遲一小段時間再加透明度動畫，否則看不出效果
                setTimeout(() => mobileMenu.classList.remove('opacity-0'), 10);
                document.body.style.overflow = 'hidden'; // 防止背景滾動
            } else {
                mobileMenu.classList.add('opacity-0');
                setTimeout(() => mobileMenu.classList.add('hidden'), 300);
                document.body.style.overflow = '';
            }
            
            menuIcon.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
        });

        // 覆蓋層內部關閉按鈕
        const menuCloseBtn = document.getElementById('mobile-menu-close');
        if (menuCloseBtn) {
            menuCloseBtn.addEventListener('click', () => {
                mobileMenu.classList.add('opacity-0');
                setTimeout(() => {
                    mobileMenu.classList.add('hidden');
                    document.body.style.overflow = '';
                }, 300);
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
            });
        }

        // 點擊手機版選單連結後自動關閉選單
        const mobileLinks = document.querySelectorAll('.mobile-link');
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('opacity-0');
                setTimeout(() => {
                    mobileMenu.classList.add('hidden');
                    document.body.style.overflow = '';
                }, 300);
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
            });
        });
    </script>

    <!-- Hero 輪播邏輯 -->
    <script>
        (function () {
            const TOTAL = 2;
            const INTERVAL = 5000;
            let current = 0;
            let timer = null;

            const slides = document.querySelectorAll('.hero-slide');
            const dots = document.querySelectorAll('.hero-dot');
            const heroCarousel = document.getElementById('hero-carousel');
            const infoCard = document.getElementById('hero-info-card');
            const video = document.getElementById('hero-video');
            const ppIcon = document.getElementById('pp-icon');
            const unmuteIcon = document.getElementById('unmute-icon');
            const unmuteLabel = document.getElementById('unmute-label');

            var SVG_PAUSE = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
            var SVG_PLAY  = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
            var SVG_MUTED = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>';
            var SVG_SOUND = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>';

            // 播放/暫停按鈕
            document.getElementById('playpause-btn').addEventListener('click', function () {
                if (!video) return;
                if (video.paused) {
                    video.play();
                    ppIcon.innerHTML = SVG_PAUSE;
                } else {
                    video.pause();
                    ppIcon.innerHTML = SVG_PLAY;
                }
            });

            // 靜音切換按鈕
            document.getElementById('unmute-btn').addEventListener('click', function () {
                if (!video) return;
                video.muted = !video.muted;
                unmuteIcon.innerHTML = video.muted ? SVG_MUTED : SVG_SOUND;
                unmuteLabel.textContent = video.muted ? '開聲音' : '靜音';
            });

            function goTo(index, userInitiated) {
                slides[current].classList.add('hidden');
                dots[current].classList.remove('is-active');

                current = index;

                slides[current].classList.remove('hidden');
                dots[current].classList.add('is-active');

                if (current === 0) {
                    // 切回肖像：暫停影片、重置靜音、恢復資訊卡配色、隱藏 Threads 按鈕、重啟自動輪播
                    if (video) { video.pause(); video.muted = true; }
                    if (unmuteIcon) unmuteIcon.innerHTML = SVG_MUTED;
                    if (unmuteLabel) unmuteLabel.textContent = '開聲音';
                    if (ppIcon) ppIcon.innerHTML = SVG_PAUSE;
                    // 恢復資訊卡原始配色（较沈嗯、較低對比）
                    if (infoCard) {
                        infoCard.style.backgroundColor = 'rgba(111, 121, 99, 0.48)';
                        infoCard.classList.remove('video-mode-hidden');
                    }
                    // 隱藏 Threads 按鈕
                    var threadsBtn = document.getElementById('threads-btn');
                    if (threadsBtn) {
                        threadsBtn.style.display = 'none';
                        threadsBtn.classList.remove('threads-cta-glow');
                    }
                    if (userInitiated) { startAuto(); }
                } else {
                    // 切到影片：強化資訊卡陰影、開始播放、顯示 Threads 按鈕、停止自動輪播
                    if (ppIcon) ppIcon.innerHTML = SVG_PAUSE;
                    if (video) { video.play().catch(function(e){}); }
                    // 增強資訊卡背景（更沈嗯、更渕沙、提高可讀性）
                    if (infoCard) {
                        infoCard.style.backgroundColor = 'rgba(111, 121, 99, 0.88)';
                        infoCard.classList.add('video-mode-hidden');
                    }
                    // 顯示 Threads 按鈕
                    var threadsBtn = document.getElementById('threads-btn');
                    if (threadsBtn) {
                        threadsBtn.style.display = 'flex';
                        threadsBtn.classList.add('threads-cta-glow');
                    }
                    clearInterval(timer);
                    timer = null;
                }
            }

            function startAuto() {
                clearInterval(timer);
                timer = setInterval(function () {
                    goTo((current + 1) % TOTAL, false);
                }, INTERVAL);
            }

            dots.forEach(function (dot) {
                dot.addEventListener('click', function () {
                    clearInterval(timer);
                    timer = null;
                    goTo(parseInt(this.dataset.index), true);
                });
            });

            // 手機左右滑動切換輪播
            if (heroCarousel) {
                let touchStartX = 0;
                let touchStartY = 0;

                heroCarousel.addEventListener('touchstart', function (e) {
                    if (!e.touches || e.touches.length !== 1) { return; }
                    touchStartX = e.touches[0].clientX;
                    touchStartY = e.touches[0].clientY;
                }, { passive: true });

                heroCarousel.addEventListener('touchend', function (e) {
                    if (!e.changedTouches || e.changedTouches.length !== 1) { return; }

                    var touchEndX = e.changedTouches[0].clientX;
                    var touchEndY = e.changedTouches[0].clientY;
                    var deltaX = touchEndX - touchStartX;
                    var deltaY = touchEndY - touchStartY;
                    var absX = Math.abs(deltaX);
                    var absY = Math.abs(deltaY);

                    // 以水平滑動為主，且避免與垂直捲動誤判
                    if (absX < 45 || absX <= absY) { return; }

                    clearInterval(timer);
                    timer = null;

                    if (deltaX < 0) {
                        goTo((current + 1) % TOTAL, true);
                    } else {
                        goTo((current - 1 + TOTAL) % TOTAL, true);
                    }
                }, { passive: true });
            }

            startAuto();
        })();
    </script>
</body>
