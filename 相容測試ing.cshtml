@model CrownLaw.Models.Index
@{
    // 由於新版設計是包含 <html> 與 <head> 的完整獨立頁面，這裡將 Layout 設為 null
    Layout = null; 
    ViewBag.Title = "CrownCPA 冠恆联合會計師事務所 | 現代創新";
	var threadsUrl = "https://www.threads.net/@tax_grandpa/post/DXmRSi6ivvI";
	var threadsProfileUrl = "https://www.threads.net/@tax_grandpa";
}

<!DOCTYPE html>
<html lang="zh-TW" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 配置 Tailwind 暖調企業綠主題色 -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Inter"', 'system-ui', '-apple-system', 'BlinkMacSystemFont', '"Segoe UI"', 'Roboto', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            light: '#f6f5ee',    /* 暖霧綠白 */
                            muted: '#cfcdbb',    /* 暖鼠尾草 */
                            accent: '#788c61',   /* 暖橄欖綠 */
                            accentHover: '#687953',
                            primary: '#596d50',  /* 主綠 */
                            surface: '#687b5d',  /* 深綠卡片色 */
                            dark: '#465846',     /* 墨綠 */
                            crown: '#a96a6d',
                            crownSoft: '#d8c1c3'
                        }
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'blob': 'blob 7s infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        },
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' },
                        }
                    }
                }
            }
        }
    </script>
    <!-- 引入 Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* 隱藏滾動條但保留功能 */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        

        .bg-grain {
            background-image:
                radial-gradient(rgba(255, 255, 255, 0.04) 0.8px, transparent 0.8px),
                radial-gradient(rgba(32, 42, 28, 0.028) 0.8px, transparent 0.8px);
            background-position: 0 0, 12px 12px;
            background-size: 24px 24px;
        }

        .hero-wash {
            background:
                radial-gradient(circle at 16% 34%, rgba(246, 239, 224, 0.14), transparent 30%),
                radial-gradient(circle at 76% 22%, rgba(207, 205, 187, 0.08), transparent 24%),
                radial-gradient(circle at 74% 76%, rgba(216, 193, 195, 0.05), transparent 22%),
                linear-gradient(135deg, #667757 0%, #596d50 46%, #53644b 100%);
        }

        .hero-grid {
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.028) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
            background-size: 72px 72px;
        }

        .hero-photo-blend {
            background-image: url('@Url.Content("~/images/hero測試.png")');
            background-size: cover;
            background-position: center;
            filter: saturate(78%) contrast(94%);
            mix-blend-mode: soft-light;
        }

        .glass-oval {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.26));
            backdrop-filter: blur(20px) saturate(145%);
            -webkit-backdrop-filter: blur(20px) saturate(145%);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.62),
                inset 0 -1px 0 rgba(255, 255, 255, 0.2),
                0 10px 28px rgba(20, 35, 24, 0.12);
        }

        .glass-pill {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.32));
            backdrop-filter: blur(22px) saturate(150%);
            -webkit-backdrop-filter: blur(22px) saturate(150%);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.7),
                0 6px 20px rgba(44, 58, 45, 0.07);
        }

        .glass-cta {
            background: linear-gradient(180deg, rgba(36, 63, 43, 0.92), rgba(24, 47, 31, 0.9));
            backdrop-filter: blur(18px) saturate(130%);
            -webkit-backdrop-filter: blur(18px) saturate(130%);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.1),
                0 10px 22px rgba(12, 26, 17, 0.18);
        }

        .hero-stats-shell {
            background: linear-gradient(180deg, rgb(246, 247, 242), rgb(239, 241, 234));
            box-shadow: 0 24px 48px rgba(41, 58, 40, 0.16);
        }

        @@keyframes ctaBreathGlow {
            0%, 100% {
                box-shadow:
                    0 10px 24px rgba(21,41,28,0.34),
                    inset 0 1px 0 rgba(255,255,255,0.2),
                    0 0 0 rgba(184, 207, 152, 0.0);
            }
            50% {
                box-shadow:
                    0 14px 28px rgba(21,41,28,0.4),
                    inset 0 1px 0 rgba(255,255,255,0.24),
                    0 0 22px rgba(184, 207, 152, 0.52);
            }
        }

        .threads-cta-glow {
            animation: ctaBreathGlow 2.4s ease-in-out infinite;
        }

        /* Hero 互動點：播放中更亮且帶光暈，hover 顯示說明文字 */
        .hero-dot {
            position: relative;
            width: 11px;
            height: 11px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.38);
            border: 1px solid rgba(255, 255, 255, 0.52);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
            transition: transform 0.22s ease, background-color 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
        }
        .hero-dot:hover {
            background: rgba(255, 255, 255, 0.7);
            transform: scale(1.12);
        }
        .hero-dot.is-active {
            background: rgba(255, 255, 255, 0.96);
            border-color: rgba(255, 255, 255, 0.95);
            transform: scale(1.18);
            box-shadow:
                0 0 0 4px rgba(255, 255, 255, 0.16),
                0 0 18px rgba(255, 255, 255, 0.55),
                inset 0 1px 0 rgba(255, 255, 255, 0.88);
        }
        @@media (hover: hover) and (pointer: fine) {
            .hero-dot::after {
                content: attr(data-tip);
                position: absolute;
                right: calc(100% + 10px);
                top: 50%;
                transform: translateY(-50%) translateX(4px);
                opacity: 0;
                pointer-events: none;
                white-space: nowrap;
                font-size: 11px;
                letter-spacing: 0.08em;
                font-weight: 700;
                color: #f8fafc;
                padding: 5px 9px;
                border-radius: 999px;
                border: 1px solid rgba(255, 255, 255, 0.34);
                background: rgba(58, 71, 54, 0.7);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
                transition: opacity 0.2s ease, transform 0.2s ease;
            }
            .hero-dot::before {
                content: '';
                position: absolute;
                right: calc(100% + 4px);
                top: 50%;
                transform: translateY(-50%) translateX(4px);
                opacity: 0;
                pointer-events: none;
                width: 0;
                height: 0;
                border-top: 5px solid transparent;
                border-bottom: 5px solid transparent;
                border-left: 6px solid rgba(58, 71, 54, 0.7);
                transition: opacity 0.2s ease, transform 0.2s ease;
            }
            .hero-dot:hover::after,
            .hero-dot:hover::before {
                opacity: 1;
                transform: translateY(-50%) translateX(0);
            }
        }

        /* 影片播放時：所長資訊卡淡出，桌機 hover 時可暫時顯示 */
        #hero-info-card {
            transition: opacity 0.35s ease, transform 0.35s ease, background-color 0.3s ease;
        }
        #hero-info-card.video-mode-hidden {
            opacity: 0;
            transform: translateY(8px);
        }
        @@media (hover: hover) and (pointer: fine) {
            #hero-info-card.video-mode-hidden:hover {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 影片控制列：手機寬度改兩行堆疊 */
        /* 桌機並排時 Threads 按鈕用短文字，手機堆疊時用完整文字 */
        .threads-label-short { display: none; }
        .threads-label-full  { display: inline; }
        @@media (min-width: 1024px) {
            .threads-label-short { display: inline; }
            .threads-label-full  { display: none; }
        }

            /* 極小手機：同樣用短文字，隱藏笑臉圖示 */
            @@media (max-width: 400px) {
                .threads-label-short { display: inline; }
                .threads-label-full  { display: none; }
                .threads-btn-icon    { display: none !important; }

                /* 覆蓋 <=480 規則，強制三顆按鈕同一排 */
                #video-controls {
                    left: 12px !important;
                    right: 12px !important;
                    max-width: none !important;
                    gap: 8px !important;
                    padding: 8px 10px !important;
                    flex-wrap: nowrap !important;
                    justify-content: space-between !important;
                }
                #threads-btn {
                    width: auto !important;
                    flex: 1 1 auto !important;
                    min-width: 0 !important;
                    padding: 10px 12px !important;
                    font-size: 13px !important;
                    gap: 6px !important;
                    justify-content: center !important;
                }
                #playpause-btn {
                    width: 42px !important;
                    height: 42px !important;
                }
                #unmute-btn {
                    padding: 10px 12px !important;
                    gap: 6px !important;
                    font-size: 13px !important;
                }
                #unmute-label {
                    display: none !important;
                }
            }

        @@media (max-width: 480px) {
            #video-controls {
                left: 12px !important;
                right: 12px !important;
                border-radius: 18px !important;
                justify-content: flex-end !important;
                flex-wrap: wrap !important;
            }
            #threads-btn {
                width: 100%;
                justify-content: center;
            }
        }

        /* ===== 手機選單覆蓋層：精緻網點 ===== */
        .mobile-menu-overlay {
            background: rgba(246, 245, 238, 0.97);
            backdrop-filter: blur(28px) saturate(160%);
            -webkit-backdrop-filter: blur(28px) saturate(160%);
            overflow: hidden;
        }
        .mobile-menu-overlay::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(#596d50 1.3px, transparent 1.3px);
            background-size: 22px 22px;
            opacity: 0.07;
            -webkit-mask-image: linear-gradient(135deg, black 0%, black 50%, transparent 82%);
            mask-image: linear-gradient(135deg, black 0%, black 50%, transparent 82%);
            pointer-events: none;
            z-index: 0;
        }
    </style>
</head>
<body class="bg-brand-light font-sans text-slate-800 antialiased selection:bg-brand-accent selection:text-white">

    <!-- 現代懸浮導覽列 (Floating Pill Nav) -->
