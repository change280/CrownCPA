                    <i data-lucide="x" id="close-icon" class="h-5 w-5 hidden"></i>
                </button>
            </div>
        </nav>
    </div>

    <!-- 手機版選單覆蓋層 -->
    <div id="mobile-menu" class="pt-28 fixed inset-0 z-40 hidden flex-col opacity-0 transition-opacity duration-300 mobile-menu-overlay">

        <!-- 裝飾光暈（右下） -->
