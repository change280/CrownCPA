        <!-- 裝飾光暈（左上） -->
        <div class="absolute top-0 left-0 w-[40vw] h-[40vw] bg-brand-muted/12 rounded-full blur-[70px] pointer-events-none"></div>
        <!-- 大型裝飾形狀 -->
        <div class="absolute top-[18%] left-[-6%] pointer-events-none select-none opacity-[0.04]">
