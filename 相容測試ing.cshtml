                <span class="block text-[1.75rem] font-black text-slate-800 group-hover:text-brand-accent transition-colors duration-300 leading-tight">資源分享</span>
                <span class="block text-[9px] tracking-[0.32em] text-slate-400 mt-0.5 uppercase group-hover:text-brand-accent/60 transition-colors">Resources</span>
            </a>
            <a href="#news" class="mobile-link group text-right">
                <span class="block text-[1.75rem] font-black text-slate-800 group-hover:text-brand-accent transition-colors duration-300 leading-tight">最新洞察</span>
                <span class="block text-[9px] tracking-[0.32em] text-slate-400 mt-0.5 uppercase group-hover:text-brand-accent/60 transition-colors">Insights &amp; News</span>
            </a>
        </div>

        <!-- 底部 CTA -->
        <div class="relative z-10 px-6 pb-10">
            <a href="#contact" class="mobile-link flex items-center justify-center gap-2 px-8 py-4 bg-brand-primary text-white rounded-full text-base font-bold shadow-xl shadow-brand-primary/20 hover:bg-brand-accent transition-colors w-full">
                立即預約專業諮詢
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
